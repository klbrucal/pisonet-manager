<Window x:Class="PisonetManager.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Pisonet Manager"
        Height="820"
        Width="1280"
        MinHeight="560"
        MinWidth="840"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F4F6F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="AppToolbar"
                Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="#D6DDE5"
                BorderThickness="0,0,0,1"
                Visibility="Collapsed">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Text="Pisonet Manager" />
                <TextBlock x:Name="StatusText"
                           Grid.Column="1"
                           Margin="18,0"
                           VerticalAlignment="Center"
                           Foreground="#5D6D7E"
                           Text="Connected" />
                <Button Grid.Column="2"
                        MinWidth="84"
                        Height="32"
                        Click="ReloadButton_Click"
                        Content="Reload" />
            </Grid>
        </Border>

        <Grid x:Name="LoginView" Grid.RowSpan="2">
            <Border Width="420"
                    Padding="28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#FFFFFF"
                    BorderBrush="#D6DDE5"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock Margin="0,0,0,22"
                               FontSize="28"
                               FontWeight="Bold"
                               Text="Pisonet Manager" />

                    <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Server" />
                    <TextBox x:Name="ServerInput"
                             Height="40"
                             Margin="0,0,0,14"
                             Padding="10,8"
                             Text="http://192.168.0.5:8000" />

                    <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Location" />
                    <ComboBox x:Name="LocationInput"
                              Height="40"
                              Margin="0,0,0,14"
                              Padding="10,6"
                              SelectedIndex="0">
                        <ComboBoxItem Content="All" />
                        <ComboBoxItem Content="Test" />
                        <ComboBoxItem Content="Aprang's Pisonet" />
                    </ComboBox>

                    <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Password" />
                    <PasswordBox x:Name="PasswordInput"
                                 Height="40"
                                 Margin="0,0,0,14"
                                 Padding="10,8"
                                 KeyDown="PasswordInput_KeyDown" />

                    <TextBlock x:Name="LoginError"
                               Margin="0,0,0,12"
                               Foreground="#A93226"
                               TextWrapping="Wrap"
                               Visibility="Collapsed" />

                    <Button x:Name="LoginButton"
                            Height="42"
                            Click="LoginButton_Click"
                            Content="Sign in" />
                </StackPanel>
            </Border>
        </Grid>

        <wv2:WebView2 x:Name="Browser"
                      Grid.Row="1"
                      Visibility="Collapsed" />
    </Grid>
</Window>
