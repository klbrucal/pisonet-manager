  "components": {
    "schemas": {
      "ApplicationSummary": {
        "properties": {
          "pid": {
            "type": "integer",
            "title": "Pid"
          },
          "process_name": {
            "type": "string",
            "title": "Process Name"
          },
          "window_title": {
            "type": "string",
            "title": "Window Title"
          }
        },
        "type": "object",
        "required": [
          "pid",
          "process_name",
          "window_title"
        ],
        "title": "ApplicationSummary"
      },
      "ClientSummary": {
        "properties": {
          "location": {
            "type": "string",
            "title": "Location"
          },
          "pc_name": {
            "type": "string",
            "title": "Pc Name"
          },
          "online": {
            "type": "boolean",
            "title": "Online"
          },
          "connected_at": {
            "type": "string",
            "title": "Connected At"
          },
          "last_seen_at": {
            "type": "string",
            "title": "Last Seen At"
          },
          "active_application": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ApplicationSummary"
              },
              {
                "type": "null"
              }
            ]
          },
          "applications": {
            "items": {
              "$ref": "#/components/schemas/ApplicationSummary"
            },
            "type": "array",
            "title": "Applications"
          },
          "screen_monitoring": {
            "type": "boolean",
            "title": "Screen Monitoring"
          },
          "idle_seconds": {
            "type": "integer",
            "title": "Idle Seconds"
          },
          "activity_status": {
            "type": "string",
            "title": "Activity Status"
          }
        },
        "type": "object",
        "required": [
          "location",
          "pc_name",
          "online",
          "connected_at",
          "last_seen_at",
          "active_application",
          "applications",
          "screen_monitoring",
          "idle_seconds",
          "activity_status"
        ],
        "title": "ClientSummary"
      },
      "DashboardSettings": {
        "properties": {
          "idle_threshold_minutes": {
            "type": "integer",
            "title": "Idle Threshold Minutes"
          }
        },
        "type": "object",
        "required": [
          "idle_threshold_minutes"
        ],
        "title": "DashboardSettings"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "LoginRequest": {
        "properties": {
          "location": {
            "type": "string",
            "title": "Location"
          },
          "password": {
            "type": "string",
            "title": "Password"
          }
        },
        "type": "object",
        "required": [
          "location",
          "password"
        ],
        "title": "LoginRequest"
      },
      "UpdateSettingsRequest": {
        "properties": {
          "idle_threshold_minutes": {
            "type": "integer",
            "maximum": 1440.0,
            "minimum": 1.0,
            "title": "Idle Threshold Minutes"
          }
        },
        "type": "object",
        "required": [
          "idle_threshold_minutes"
        ],
        "title": "UpdateSettingsRequest"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
